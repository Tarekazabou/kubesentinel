FROM python:3.9-slim-bookworm
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY ai-module/requirements.txt .
RUN pip install --no-cache-dir --retries 5 --default-timeout=30 -r requirements.txt
COPY ai-module/ ./
RUN mkdir -p /app/forensics /app/models

EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import requests; response = requests.get('http://localhost:5000/health'); exit(0) if response.status_code == 200 else exit(1)"

CMD ["python", "server.py"]