FROM python:3.12-slim
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY ai-module/requirements.txt .
RUN pip install --no-cache-dir --retries 5 --default-timeout=30 -r requirements.txt \
    && pip install --no-cache-dir gunicorn==22.0.0
COPY ai-module/ ./
RUN mkdir -p /app/forensics /app/models

# Run as non-root for defence in depth.
RUN groupadd -r sentinel && useradd -r -g sentinel -d /app -s /sbin/nologin sentinel \
    && chown -R sentinel:sentinel /app

EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5000/health')"

USER sentinel

CMD ["gunicorn", "--workers", "4", "--bind", "0.0.0.0:5000", "--timeout", "60", "--access-logfile", "-", "server:app"]