# STAGE 1: Builder — compile native dependencies (scikit-learn, etc.)
# This stage is cached independently, reducing rebuild time on code changes
FROM python:3.11-slim-bullseye AS builder

WORKDIR /build

ENV DEBIAN_FRONTEND=noninteractive

# Install build tools only in builder stage
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy and build wheels (layer cache friendly)
COPY ai-module/requirements.txt .
RUN pip install --upgrade pip setuptools wheel && \
    pip wheel --no-cache-dir --retries 5 --default-timeout=30 -r requirements.txt

# STAGE 2: Runtime — lean image with only runtime dependencies
FROM python:3.11-slim-bullseye

WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive

# Copy pre-built wheels from builder stage and install runtime
COPY --from=builder /build/dist/ /tmp/wheels/
COPY ai-module/requirements.txt .
RUN pip install --upgrade pip && \
    pip install --no-cache-dir --no-index --find-links=/tmp/wheels/ -r requirements.txt && \
    pip install --no-cache-dir gunicorn==22.0.0 && \
    rm -rf /tmp/wheels /app/requirements.txt

# Copy application code
COPY ai-module/ ./

# Pre-create runtime directories
# /app/forensics  — forensic JSON vault
# /app/models     — Isolation Forest baseline pickle
# /app/staging.db — SQLite staging vault (triage layer)
RUN mkdir -p /app/forensics /app/models
RUN groupadd -r sentinel \
    && useradd -r -g sentinel -d /app -s /sbin/nologin sentinel \
    && chown -R sentinel:sentinel /app

EXPOSE 5000

# start-period=30s: cold-start includes model bootstrap + SQLite schema init
# (scikit-learn synthetic data generation can take 8-12s on first run)
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5000/health')"

USER sentinel

# IMPORTANT — single worker + 4 threads, NOT 4 workers.
#
# The triage worker (TriageWorker) is a daemon thread started inside server.py
# at Flask init time. With --workers > 1, Gunicorn forks N processes and each
# independently starts a TriageWorker, causing all N workers to race on the
# same SQLite staging table → duplicate forensic writes + triage conflicts.
#
# --workers 1  → one process, one TriageWorker, no SQLite race condition
# --threads 4  → equivalent I/O throughput for a network-bound Flask service
CMD ["gunicorn", \
     "--workers", "1", \
     "--threads", "4", \
     "--bind", "0.0.0.0:5000", \
     "--timeout", "60", \
     "--access-logfile", "-", \
     "server:app"]